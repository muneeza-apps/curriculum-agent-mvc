# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Azure OpenAI (required for live AI generation) ────────
# Get these from: https://portal.azure.com → Azure OpenAI resource
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ── Microsoft Foundry IQ (optional — has static fallback) ─
# Get from: https://ai.azure.com → your project → connection string
FOUNDRY_PROJECT_CONNECTION_STRING=your_foundry_connection_string_here
